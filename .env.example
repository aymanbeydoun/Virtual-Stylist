# Copy to .env (gitignored) and fill in. Defaults below assume `docker compose -f infra/dev/docker-compose.yaml up -d`.

# --- Core ---
ENVIRONMENT=development
SECRET_KEY=replace-me-with-32-bytes-of-random

# --- Database ---
DATABASE_URL=postgresql+asyncpg://stylist:stylist@localhost:5433/virtual_stylist
REDIS_URL=redis://localhost:6380/0

# --- Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
GCS_BUCKET=

# --- Auth (Auth0 / Clerk) ---
# Set DEV_AUTH_BYPASS=true to trust X-Dev-User-Id header from the mobile client (dev only).
AUTH_ISSUER=
AUTH_AUDIENCE=virtual-stylist-api
AUTH_JWKS_URL=
DEV_AUTH_BYPASS=true

# --- Model gateway ---
# `stub` for offline dev (no cost, plausible-fake outputs).
# `anthropic` flips on the real AI stack: Claude Vision (tagging) + Claude (stylist)
# + Replicate (bg-removal + CLIP embeddings). Needs both keys below.
MODEL_GATEWAY_BACKEND=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# Replicate: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Defaults pinned to specific versions for reproducibility. Override only when intentionally upgrading.
REPLICATE_BG_REMOVAL_MODEL=lucataco/remove-bg:95fcc2a26d3899cd6c2691c900465aaeff466285a65c14638cc5f36f34befaf1
REPLICATE_CLIP_MODEL=krthr/clip-embeddings:1c0371070cb827ec3c7f2f28adcdde54b50dcd239aa6faea0bc98b174ef03fb4
# Google nano-banana (Gemini 2.5 image edit) is commercial-licensed, single-call
# multi-garment, ~$0.04/render, ~8-12s latency. IDM-VTON is higher fidelity but
# CC BY-NC-SA — not usable for a commercial product.
REPLICATE_TRYON_MODEL=google/nano-banana:5bdc2c7cd642ae33611d8c33f79615f98ff02509ab8db9d8ec1cc6c36d378fba

# --- Weather: https://home.openweathermap.org/api_keys (free tier ok) ---
OPENWEATHER_API_KEY=

# --- Mobile ---
# Build-time. For Android emulator use http://10.0.2.2:8000. For a real device use LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:8000
