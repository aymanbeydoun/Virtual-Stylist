# Backend
DATABASE_URL=postgresql+asyncpg://stylist:stylist@localhost:5432/virtual_stylist
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-me-with-32-bytes-of-random
ENVIRONMENT=development

# Storage (local-disk in dev; GCS in staging/prod)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
GCS_BUCKET=

# Auth (Auth0 / Clerk)
AUTH_ISSUER=https://example.auth0.com/
AUTH_AUDIENCE=virtual-stylist-api
AUTH_JWKS_URL=https://example.auth0.com/.well-known/jwks.json
DEV_AUTH_BYPASS=true

# Model gateway
MODEL_GATEWAY_BACKEND=stub
ANTHROPIC_API_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1

# Weather
OPENWEATHER_API_KEY=

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:8000
