# Production env template. Real values live in:
#  - Cloud Run env (per-service)
#  - GitHub Actions secrets (CI/CD)
#  - EAS secret store (mobile builds)
# Never commit a real .env.production.

ENVIRONMENT=production
SECRET_KEY=${SECRET_KEY}  # 32-byte random, rotated quarterly via Secret Manager

# Database — Cloud SQL via the proxy or private IP
DATABASE_URL=postgresql+asyncpg://stylist:${DB_PASSWORD}@/virtual_stylist?host=/cloudsql/${CLOUDSQL_INSTANCE}

# Redis — Memorystore
REDIS_URL=rediss://:${REDIS_PASSWORD}@${REDIS_HOST}:6379/0

# Storage — GCS bucket with CMEK
STORAGE_BACKEND=gcs
GCS_BUCKET=virtual-stylist-prod
# Workload identity: Cloud Run service account has roles/storage.objectAdmin on the bucket

# Auth — Auth0 / Clerk tenant
AUTH_ISSUER=https://auth.virtualstylist.com/
AUTH_AUDIENCE=virtual-stylist-api
AUTH_JWKS_URL=https://auth.virtualstylist.com/.well-known/jwks.json
DEV_AUTH_BYPASS=false

# Model gateway
MODEL_GATEWAY_BACKEND=anthropic
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
VERTEX_PROJECT=virtual-stylist-prod
VERTEX_LOCATION=us-central1

# External APIs
OPENWEATHER_API_KEY=${OPENWEATHER_API_KEY}

# Mobile (built via EAS, baked at build time)
# Set in eas.json secrets, not here:
#   EXPO_PUBLIC_API_URL=https://api.virtualstylist.com
